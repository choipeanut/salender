# Shared
NODE_ENV=development
TZ=Asia/Seoul

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Collector Worker
COLLECTOR_DEFAULT_BRAND_SLUG=steam
COLLECTOR_MAX_RETRIES=3
COLLECTOR_INITIAL_BACKOFF_MS=250
COLLECTOR_MAX_BACKOFF_MS=4000
COLLECTOR_RATE_LIMIT_PER_BRAND_MS=15000

# Push (Expo)
EXPO_PUSH_ENDPOINT=https://exp.host/--/api/v2/push/send
EXPO_ACCESS_TOKEN=
PUSH_MAX_RETRIES=3
PUSH_INITIAL_BACKOFF_MS=250
PUSH_MAX_BACKOFF_MS=4000

# Admin Web
ADMIN_WEB_PORT=3100
NEXT_PUBLIC_ADMIN_TITLE=SaleCalendar Admin Ops
NEXT_PUBLIC_API_BASE_URL=http://localhost:3100
